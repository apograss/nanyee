generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════
// 用户与认证
// ═══════════════════════════════════════

model User {
  id              String    @id @default(cuid())
  email           String?   @unique
  username        String    @unique
  passwordHash    String
  nickname        String?
  avatarUrl       String?
  role            String    @default("contributor") // contributor | admin
  status          String    @default("active") // active | banned | deleted
  emailVerifiedAt DateTime?
  lastReadAnnouncementAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  messages     Message[]
  conversations Conversation[]
  articles     Article[]       @relation("ArticleAuthor")
  editedArticles Article[]     @relation("ArticleLastEditor")
  lockedArticles Article[]     @relation("ArticleLocker")
  articleRevisions ArticleRevision[]
  quizAttempts QuizAttempt[]
  sessions     Session[]
  apiTokens    ApiToken[]
  comments     Comment[]
  createdWikiCategories WikiCategory[] @relation("WikiCategoryCreatedBy")
  updatedWikiCategories WikiCategory[] @relation("WikiCategoryUpdatedBy")
  ocrSamples   OcrSample[]
  bbsTopics    BbsTopic[]  @relation("BbsTopicAuthor")
  bbsReplies   BbsReply[]  @relation("BbsReplyAuthor")
  evalTask     EvalTask?
}

model EvalTask {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  smuAccount      String
  smuPasswordEnc  String
  enabled         Boolean   @default(true)
  lastRunAt       DateTime?
  lastRunStatus   String?
  lastRunLog      String?
  totalRuns       Int       @default(0)
  totalEvaluated  Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([enabled, lastRunAt])
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  ip               String?
  userAgent        String?
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  revokedAt        DateTime?
  lastSeenAt       DateTime  @default(now())
  revokedReason    String?   // logout | revoke_other_sessions | password_changed | email_changed | token_replay | admin_revoke

  @@index([userId])
  @@index([expiresAt])
  @@index([userId, revokedAt, expiresAt])
  @@index([userId, lastSeenAt])
}

model EmailVerification {
  id        String    @id @default(cuid())
  email     String
  codeHash  String
  purpose   String    @default("register")
  requestId String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([email, purpose, requestId, usedAt, expiresAt])
  @@index([requestId])
  @@index([expiresAt])
}

model QuizQuestion {
  id       String  @id @default(cuid())
  question String
  options  String  // JSON: ["A","B","C","D"]
  answer   Int
  active   Boolean @default(true)
}

model QuizAttempt {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  score     Int
  passed    Boolean
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model RegistrationChallenge {
  id              String    @id @default(cuid())
  method          String    // email | quiz
  email           String?
  questionIdsJson String?   // quiz: JSON array of question IDs
  verifiedAt      DateTime?
  expiresAt       DateTime
  consumedAt      DateTime?
  verifyAttempts  Int       @default(0)
  ip              String?
  userAgent       String?
  createdAt       DateTime  @default(now())

  @@index([expiresAt])
  @@index([method, expiresAt])
  @@index([email, method, consumedAt])
}

model EmailChangeRequest {
  id                 String    @id @default(cuid())
  userId             String
  currentEmail       String?
  newEmail           String
  oldEmailVerifiedAt DateTime?
  newEmailVerifiedAt DateTime?
  expiresAt          DateTime
  consumedAt         DateTime?
  cancelledAt        DateTime?
  verifyAttemptsOld  Int       @default(0)
  verifyAttemptsNew  Int       @default(0)
  ip                 String?
  userAgent          String?
  createdAt          DateTime  @default(now())

  @@index([userId, expiresAt])
  @@index([newEmail, consumedAt])
  @@index([expiresAt])
}

model OAuthAuthorizationRequest {
  id                  String    @id @default(cuid())
  userId              String
  clientId            String
  redirectUri         String
  scope               String
  state               String?
  nonce               String?
  codeChallenge       String?
  codeChallengeMethod String?
  csrfTokenHash       String
  expiresAt           DateTime
  consumedAt          DateTime?
  deniedAt            DateTime?
  createdAt           DateTime  @default(now())

  @@index([userId, expiresAt])
  @@index([clientId, expiresAt])
  @@index([expiresAt])
}

// ═══════════════════════════════════════
// 内容
// ═══════════════════════════════════════

model Article {
  id           String    @id @default(cuid())
  title        String
  slug         String    @unique
  content      String    // HTML (new) or Markdown (legacy)
  format       String    @default("html") // html | markdown
  summary      String?
  category     String?
  categoryId   String?
  categoryRef  WikiCategory? @relation("ArticleCategory", fields: [categoryId], references: [id], onDelete: SetNull)
  tags         String?   // JSON string
  status       String    @default("published") // published | hidden
  viewCount    Int       @default(0)
  authorId     String
  author       User      @relation("ArticleAuthor", fields: [authorId], references: [id])
  lastEditorId String?
  lastEditor   User?     @relation("ArticleLastEditor", fields: [lastEditorId], references: [id])
  isLocked     Boolean   @default(false)
  lockedAt     DateTime?
  lockedBy     String?
  locker       User?     @relation("ArticleLocker", fields: [lockedBy], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  publishedAt  DateTime?

  isPinned     Boolean   @default(false)
  pinnedAt     DateTime?

  revisions    ArticleRevision[]
  comments     Comment[]

  @@index([status])
  @@index([category])
  @@index([categoryId])
  @@index([publishedAt])
  @@index([isPinned, pinnedAt, publishedAt])
}

model WikiCategory {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  icon        String?
  parentId    String?
  parent      WikiCategory?  @relation("WikiCategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    WikiCategory[] @relation("WikiCategoryTree")
  sortOrder   Int            @default(0)
  createdById String?
  createdBy   User?          @relation("WikiCategoryCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   User?          @relation("WikiCategoryUpdatedBy", fields: [updatedById], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  articles    Article[]      @relation("ArticleCategory")

  @@index([parentId, sortOrder])
}

model ArticleRevision {
  id          String   @id @default(cuid())
  articleId   String
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  title       String
  content     String
  format      String   @default("html")
  summary     String?
  editorId    String
  editor      User     @relation(fields: [editorId], references: [id])
  editSummary String?
  createdAt   DateTime @default(now())

  @@index([articleId, createdAt])
  @@index([editorId, createdAt])
}

model Message {
  id        String   @id @default(cuid())
  content   String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Conversation {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String?
  messagesJson String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, updatedAt])
}

// ═══════════════════════════════════════
// AI 与工具
// ═══════════════════════════════════════

model SearchLog {
  id        String   @id @default(cuid())
  query     String
  toolUsed  String?
  userId    String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([query])
}

model ToolRun {
  id        String   @id @default(cuid())
  toolName  String
  input     String   // JSON
  output    String?  // JSON
  latencyMs Int?
  success   Boolean  @default(true)
  errorCode String?
  userId    String?
  requestId String?
  createdAt DateTime @default(now())

  @@index([toolName])
  @@index([createdAt])
}

model OcrSample {
  id            String   @id @default(cuid())
  sourcePage    String
  imageBase64   String
  correctedText String
  ocrText       String?
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  ip            String?
  createdAt     DateTime @default(now())

  @@index([sourcePage, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
}

// ═══════════════════════════════════════
// 上游 Key 管理
// ═══════════════════════════════════════

model ProviderKey {
  id           String    @id @default(cuid())
  provider     String    // "longcat"
  keyPrefix    String
  keyCipher    String    // AES-256-GCM 加密
  status       String    @default("active") // active | degraded | disabled
  weight       Int       @default(1)
  dailyLimit   Int?
  monthlyLimit Int?
  lastCheckAt  DateTime?
  lastError    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  usages       KeyUsage[]
  healthChecks KeyHealth[]

  @@index([status])
}

model KeyUsage {
  id               String      @id @default(cuid())
  providerKeyId    String
  providerKey      ProviderKey @relation(fields: [providerKeyId], references: [id])
  apiTokenId       String?
  channelId        String?
  channel          ApiChannel? @relation(fields: [channelId], references: [id])
  model            String
  promptTokens     Int
  completionTokens Int
  costUsd          Float?
  latencyMs        Int?
  success          Boolean
  errorCode        String?
  requestId        String?
  createdAt        DateTime    @default(now())

  @@index([providerKeyId, createdAt])
  @@index([apiTokenId, createdAt])
}

model KeyHealth {
  id            String      @id @default(cuid())
  providerKeyId String
  providerKey   ProviderKey @relation(fields: [providerKeyId], references: [id])
  status        String      // ok | fail | rate_limited
  responseMs    Int?
  error         String?
  checkedAt     DateTime    @default(now())

  @@index([providerKeyId, checkedAt])
}

// ═══════════════════════════════════════
// 对外 Token 发放
// ═══════════════════════════════════════

model ApiToken {
  id                String    @id @default(cuid())
  name              String
  tokenPrefix       String    @unique
  tokenHash         String
  status            String    @default("active") // active | suspended | revoked
  ownerId           String?
  owner             User?     @relation(fields: [ownerId], references: [id])
  issuedTo          String?
  description       String?
  allowedModels     String?   // JSON: ["LongCat-Flash-Chat","LongCat-Flash-Lite"]
  rateLimitRpm      Int?
  rateLimitRpd      Int?
  monthlyTokenQuota Int?
  expiresAt         DateTime?
  lastUsedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  usages            TokenUsage[]

  @@index([status])
  @@index([expiresAt])
}

model TokenUsage {
  id               String      @id @default(cuid())
  apiTokenId       String
  apiToken         ApiToken    @relation(fields: [apiTokenId], references: [id])
  channelId        String?
  channel          ApiChannel? @relation(fields: [channelId], references: [id])
  endpoint         String
  toolName         String?
  model            String
  promptTokens     Int
  completionTokens Int
  costUsd          Float?
  success          Boolean
  errorCode        String?
  responseMs       Int?
  clientIp         String?
  userAgent        String?
  requestId        String?
  createdAt        DateTime    @default(now())

  @@index([apiTokenId, createdAt])
  @@index([endpoint, createdAt])
}

// ═══════════════════════════════════════
// 渠道与审计
// ═══════════════════════════════════════

model ApiChannel {
  id            String   @id @default(cuid())
  name          String   @unique
  description   String?
  enabled       Boolean  @default(true)
  rateLimitRpm  Int?
  rateLimitRpd  Int?
  modelMapping  String?  // JSON: {"external-model": "internal-model"}
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  keyUsages    KeyUsage[]
  tokenUsages  TokenUsage[]
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  targetType String?
  targetId   String?
  payload    String?  // JSON
  createdAt  DateTime @default(now())

  @@index([action, createdAt])
  @@index([actorId, createdAt])
}

// ═══════════════════════════════════════
// 公告与链接
// ═══════════════════════════════════════

model Announcement {
  id        String   @id @default(cuid())
  content   String
  active    Boolean  @default(true)
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Link {
  id          String   @id @default(cuid())
  title       String
  url         String
  category    String   @default("general")
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([order])
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model AiServiceHealth {
  id        String   @id @default(cuid())
  provider  String
  service   String
  status    String
  latencyMs Int?
  version   String?
  lastError String?
  checkedAt DateTime @default(now())

  @@index([provider, checkedAt])
  @@index([service, checkedAt])
}

model AiProviderSnapshot {
  id                  String   @id @default(cuid())
  provider            String
  capturedAt          DateTime @default(now())
  totalAccounts       Int      @default(0)
  healthyAccounts     Int      @default(0)
  rateLimitedAccounts Int      @default(0)
  invalidAccounts     Int      @default(0)
  staleAccounts       Int      @default(0)
  unknownAccounts     Int      @default(0)
  requests1h          Int      @default(0)
  requests24h         Int      @default(0)
  successRate1h       Int      @default(100)
  successRate24h      Int      @default(100)

  @@index([provider, capturedAt])
}

model AiAccountState {
  id              String   @id @default(cuid())
  provider        String
  accountKey      String
  displayLabel    String
  status          String
  lastUsedAt      DateTime?
  lastSuccessAt   DateTime?
  lastObservedAt  DateTime?
  lastError       String?
  requestCount24h Int      @default(0)
  successRate24h  Int      @default(100)
  metadataJson    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([provider, accountKey])
  @@index([provider, status])
  @@index([updatedAt])
}

model AiIncident {
  id         String   @id @default(cuid())
  provider   String
  scope      String
  severity   String
  title      String
  message    String
  service    String?
  accountKey String?
  occurredAt DateTime @default(now())

  @@index([provider, occurredAt])
  @@index([scope, occurredAt])
  @@index([service, occurredAt])
}

// ═══════════════════════════════════════
// BBS 论坛
// ═══════════════════════════════════════

model BbsTopic {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String   @default("general") // general | study | life | trade | question
  authorId  String
  author    User     @relation("BbsTopicAuthor", fields: [authorId], references: [id])
  pinned    Boolean  @default(false)
  locked    Boolean  @default(false)
  viewCount Int      @default(0)
  replyCount Int     @default(0)
  lastReplyAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  replies   BbsReply[]

  @@index([category])
  @@index([pinned, createdAt])
  @@index([pinned, lastReplyAt])
  @@index([authorId])
}

model BbsReply {
  id        String   @id @default(cuid())
  content   String
  authorId  String
  author    User     @relation("BbsReplyAuthor", fields: [authorId], references: [id])
  topicId   String
  topic     BbsTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([topicId, createdAt])
  @@index([authorId])
}

// ═══════════════════════════════════════
// OAuth / OIDC
// ═══════════════════════════════════════

model OAuthClient {
  id           String   @id @default(cuid())
  clientId     String   @unique
  clientSecret String?  // bcrypt hash; null for public clients (PKCE)
  name         String   // Display name: "CloudMail 邮箱"
  redirectUris String   // JSON array: ["https://mail.nanyee.de/..."]
  grants       String   @default("[\"authorization_code\"]")
  scopes       String   @default("[\"openid\",\"profile\",\"email\"]")
  createdAt    DateTime @default(now())
}

model OidcCode {
  id                  String    @id @default(cuid())
  code                String    @unique
  clientId            String
  userId              String
  redirectUri         String
  scope               String
  nonce               String?
  codeChallenge       String?   // PKCE
  codeChallengeMethod String?   // "S256"
  expiresAt           DateTime
  consumedAt          DateTime?
  createdAt           DateTime  @default(now())

  @@index([expiresAt])
}

model OidcToken {
  id          String   @id @default(cuid())
  accessToken String   @unique
  clientId    String
  userId      String
  scope       String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([expiresAt])
}

// ═══════════════════════════════════════
// 百科评论
// ═══════════════════════════════════════

model Comment {
  id             String   @id @default(cuid())
  articleId      String
  article        Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  paragraphIndex Int
  content        String
  authorId       String
  author         User     @relation(fields: [authorId], references: [id])
  createdAt      DateTime @default(now())

  @@index([articleId, paragraphIndex, createdAt])
  @@index([authorId])
}
