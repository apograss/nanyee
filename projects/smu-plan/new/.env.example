# Database
DATABASE_URL="file:./dev.db"

# JWT Secrets
JWT_ACCESS_SECRET="change-me-access-secret-at-least-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-at-least-32-chars"

# Key Encryption (32-byte hex key for AES-256-GCM)
KEY_ENCRYPTION_SECRET="change-me-32-byte-hex-key-here!!"

# AI Provider
AI_BASE_URL="https://api.longcat.chat/openai/v1"
AI_DEFAULT_MODEL="LongCat-Flash-Chat"
AI_API_KEY=""
AI_FORCE_ENV_KEY="false"
AI_AVAILABLE_MODELS=""
AI_VISION_MODEL=""

# S3-compatible Object Storage (optional, falls back to local uploads)
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET=""
S3_REGION="us-east-1"
S3_OBJECT_ACL="public-read"
UPLOAD_DIR=""

# Email (for verification codes)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@nanyee.de"

# Cron Secret (for health check endpoint)
CRON_SECRET="change-me-cron-secret"

# Site
NEXT_PUBLIC_SITE_URL="https://nanyee.de"
NEXT_PUBLIC_SITE_NAME="nanyee.de"

# Forum Integration
NEXT_PUBLIC_FORUM_URL=""
FORUM_INTERNAL_BASE_URL=""

# OIDC Provider (auto-generated if empty)
OIDC_RSA_PRIVATE_KEY=""
OIDC_RSA_PUBLIC_KEY=""

# Flarum OIDC Bootstrap (one-time setup)
FLARUM_OIDC_CLIENT_ID="flarum-chat"
FLARUM_OIDC_CLIENT_SECRET=""
FLARUM_OIDC_REDIRECT_URI=""
FLARUM_OIDC_NAME="Flarum 论坛"

# CHECK Module (service health monitoring)
CHECK_PUBLIC_HOST="check.nanyee.de"
CHECK_CRON_SECRET=""
CHECK_CPA_BASE_URL="http://127.0.0.1:8317"
CHECK_CPA_API_KEY=""
CHECK_NEW_API_BASE_URL="http://127.0.0.1:3001"
CHECK_NEW_API_API_KEY=""
CHECK_NEW_API_ADMIN_URL=""
CHECK_GROK_BASE_URL="http://127.0.0.1:8000"
CHECK_GROK_API_KEY=""
CHECK_GROK_ADMIN_BASE_URL=""
CHECK_GROK_ADMIN_API_KEY=""
CHECK_GROK_ADMIN_URL=""
CHECK_CHATGPT_AUTH_DIR="/opt/cpamc/auths"
CHECK_GROK_RESULT_DIR="/opt/grok2api/result_grok"
CHECK_GROK_TOKEN_FILE="/opt/grok2api/data/token.json"
